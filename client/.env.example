# Copy to client/.env — Vite only reads VITE_* variables

# Google Sign-In (must match server GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=

# PayPal Smart Buttons (same app as server PAYPAL_CLIENT_ID)
VITE_PAYPAL_CLIENT_ID=

# Stripe (optional — if using card checkout)
VITE_STRIPE_PUBLISHABLE_KEY=

# API / WebSocket (dev: leave empty to use same origin)
VITE_PUBLIC_SITE_URL=http://localhost:5173
VITE_SOCKET_URL=

# WhatsApp FAB (optional)
VITE_WHATSAPP_NUMBER=966500000000

# Firebase push alerts (optional)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
