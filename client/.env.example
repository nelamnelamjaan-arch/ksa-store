# Copy to client/.env — Vite only reads VITE_* variables
#
# Vercel (client project, Root Directory = client):
# - Add each VITE_* below in Project → Settings → Environment Variables (Production + Preview).
# - Recommended production: leave VITE_API_URL unset so `/api` stays same-origin and
#   client/vercel.json rewrites proxy to the API. Set VITE_PUBLIC_SITE_URL to your client URL.
# - Alternative: set VITE_API_URL to the API origin for direct cross-origin calls (requires
#   CLIENT_ORIGIN on the server to include this client URL).

# Google Sign-In (must match server GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=

# PayPal JavaScript SDK v6 (same Client ID as server PAYPAL_CLIENT_ID)
VITE_PAYPAL_CLIENT_ID=your_live_client_id
VITE_PAYPAL_MODE=live

# Stripe (optional — if using card checkout)
VITE_STRIPE_PUBLISHABLE_KEY=

# Public storefront URL (SEO, share links — your deployed client origin)
# Production: https://ksa-store-client-tjx3.vercel.app
VITE_PUBLIC_SITE_URL=http://localhost:5173

# API origin (no trailing slash). Production direct-API example:
# VITE_API_URL=https://ksa-store-server-67sq.vercel.app
# Local dev + Vercel with rewrites: leave empty — relative `/api` (Vite proxy locally, vercel.json in prod).
VITE_API_URL=

# Socket.io (magic import live progress). Optional — defaults to VITE_API_URL, then page origin.
VITE_SOCKET_URL=

# WhatsApp FAB (optional)
VITE_WHATSAPP_NUMBER=966500000000

# Firebase push alerts (optional)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
