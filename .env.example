# Copy to `.env` at repo root and fill in real values. Root `.env` is loaded by the server
# and by Vite (client) when `envDir` points here.

PORT=5000
MONGODB_URI=
RAINFOREST_API_KEY=
GEMINI_API_KEY=
SERPAPI_API_KEY=
SERP_API_KEY=
FIXER_API_KEY=
# Replace API_KEY and API_SECRET with your Cloudinary credentials (or set CLOUDINARY_* vars your app expects).
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@your_cloud_name
RESEND_API_KEY=
SHOTSTACK_API_KEY=
SHOTSTACK_API_VERSION=v1
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_MODE=sandbox
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=
ADMIN_PASSWORD=
KIRAN_ADMIN_PASSWORD=
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_SITE_URL=http://localhost:5173
GEO_USE_IPAPI=true
