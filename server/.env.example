# Public browser origins allowed for CORS + Socket.io (comma-separated)
# Local dev:
# CLIENT_ORIGIN=http://localhost:5173
# Production (dev + live client):
CLIENT_ORIGIN=http://localhost:5173,https://ksa-store-client-tjx3.vercel.app

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/ksa-store

# JWT
JWT_SECRET=change-me-in-production

# Super Admin (Kiran) — seeded on startup + JWT login
ADMIN_USERNAME=Kiran
ADMIN_PASSWORD=kiran123
KIRAN_ADMIN_PASSWORD=kiran123

# Universal import / Auto-Pilot
RAINFOREST_API_KEY=
SERPAPI_API_KEY=
GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=
FIXER_API_KEY=
# Live FX (preferred) — https://www.exchangerate-api.com
EXCHANGERATE_API_KEY=
# Global parcel tracking — https://www.aftership.com/docs/tracking/quickstart/api-quick-start
AFTERSHIP_API_KEY=

# Transactional email (Resend) — glass templates: order / payment / shipping
# Set keys in .env only — never commit secrets
RESEND_API_KEY=
RESEND_FROM="KSA Store <orders@ksastore.com>"
# Logo in confirmation emails (defaults to PUBLIC_SITE_URL/favicon.svg)
# KSA_STORE_LOGO_URL=
# Production storefront: https://ksa-store-client-tjx3.vercel.app
PUBLIC_SITE_URL=http://localhost:5173
# Scraper anti-block (optional): comma-separated http proxies
# SCRAPE_PROXY_URLS=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
# SCRAPE_UA_ROTATION=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_PRODUCT_VIDEO_FOLDER=ksa-store/product-videos

# Product reel videos (Shotstack) — POST https://api.shotstack.io/edit/v1/render
SHOTSTACK_API_KEY=
# v1 = production | stage = sandbox
SHOTSTACK_API_VERSION=v1
# MP3 URL for background music on generated reels
SHOTSTACK_SOUNDTRACK_URL=
VIDEO_GENERATOR_ENABLED=true
PRODUCT_VIDEO_DURATION_SEC=15
# VIDEO_REGENERATE_ON_IMPORT=true

# Auto-Pilot cron (price/stock every 6h; OOS → status hidden)
ENABLE_CRON_AUTOPILOT=false
CRON_AUTOPILOT_RUN_ON_BOOT=false

# Top-sellers price refresh (daily — paid-order rank, re-scrape source price)
ENABLE_CRON_TOP_SELLERS_PRICE_REFRESH=false
# Default: 04:00 daily (cron expression, Asia/Riyadh via CRON_TIMEZONE)
CRON_TOP_SELLERS_SCHEDULE=0 4 * * *
CRON_TOP_SELLERS_RUN_ON_BOOT=false
TOP_SELLING_PRICE_REFRESH_LIMIT=50
TOP_SELLING_PRICE_LOOKBACK_DAYS=90

# Nightly daily profit report (23:59 — SMTP required)
ENABLE_DAILY_PROFIT_REPORT=true
CRON_TIMEZONE=Asia/Riyadh
DAILY_PROFIT_REPORT_TO=Usmanrahmaa6@gmail.com
# Optional CC (comma-separated), e.g. nelamnelamjaan@gmail.com
DAILY_PROFIT_REPORT_CC=
# Production admin UI: https://ksa-store-client-tjx3.vercel.app
ADMIN_DASHBOARD_URL=http://localhost:5173

# SMTP (Gmail app password, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="KSA Store <noreply@ksastore.com>"

# Geolocation (ipapi.co free tier — no API key) — city + country on every request
GEO_USE_IPAPI=true
# Cron stock sync: prefer Daily Essentials vendors for this ISO country (e.g. TR, US, SA)
# STOREFRONT_SYNC_COUNTRY=SA

# Scheduled scrape (axios + cheerio) — daily at 00:00 in CRON_TIMEZONE (default Asia/Riyadh, not UTC)
# Requires a long-running Node process (npm start / PM2 / Docker). Not supported on Vercel serverless cron.
ENABLE_SCRAPE_CRON=false
# CRON_SCRAPE_SCHEDULE=0 0 * * *
# CRON_SCRAPE_RUN_ON_BOOT=false
# Auto-approve new listings from scheduled scrape (default: pending review)
# SCRAPE_AUTO_APPROVE=false

# AI self-healing scrape (axios + Gemini) — same midnight schedule; GEMINI_API_KEY or GOOGLE_AI_API_KEY required
ENABLE_AI_SCRAPE_CRON=false
# CRON_AI_SCRAPE_SCHEDULE=0 0 * * *
# CRON_AI_SCRAPE_RUN_ON_BOOT=false
# GEMINI_AI_SCRAPE_MODEL=gemini-1.5-flash
# AI_SCRAPE_AUTO_APPROVE=false
# AI_SCRAPE_MAX_HTML_CHARS=120000

# Global marketplace + brand scrape (axios + Gemini, 500+ URLs from scrapedWebsites.js)
ENABLE_GLOBAL_SCRAPE_CRON=false
# CRON_GLOBAL_SCRAPE_SCHEDULE=0 0 * * *
# CRON_GLOBAL_SCRAPE_RUN_ON_BOOT=false
# GLOBAL_SCRAPE_BOOT_LIMIT=5
# GLOBAL_SCRAPE_DELAY_MS=2000
# GEMINI_GLOBAL_SCRAPE_MODEL=gemini-1.5-flash
# GLOBAL_SCRAPE_MAX_HTML_CHARS=100000
# GLOBAL_SCRAPE_AUTO_APPROVE=false

# Universal Checkout — PayPal Live (set credentials in .env only)
PAYPAL_CLIENT_ID=your_live_client_id
PAYPAL_CLIENT_SECRET=your_live_secret
PAYPAL_MODE=live
PAYPAL_DEFAULT_AMOUNT=100.00
# Checkout button currency (USD for global; set SAR + SA geo for domestic)
PAYPAL_CHECKOUT_CURRENCY=USD
PAYPAL_PROFIT_RECEIVER_EMAIL=Usmanrahmaa6@gmail.com
PAYPAL_PAYOUTS_ENABLED=true
ENABLE_SOURCE_BUY_ASSIST=false
BANK_DETAILS_PK=JazzCash: …|SadaPay: …
BANK_DETAILS_SA=Bank name: …|IBAN: …

# Optional
GOOGLE_CLIENT_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
REDIS_URL=
